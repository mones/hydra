CVSROOT=$(shell cat etc/cvs.root)
HOSTNAME:=$(shell hostname)
DATETIME:=$(shell date)

all: get-origs

get-origs: claws-mail-$(VERS).tar.gz 

claws:
	cvs -z3 -d$(CVSROOT) checkout -r gtk2 $@

update-claws: claws
	cd $< && cvs -z3 up -dP && cd ..

claws-dev: update-claws
	rm -rf $@
	cp -rp claws $@

claws-mail-$(VERS).tar.gz: claws-dev
	cd claws-dev && ./autogen.sh && make dist && cd ..
	pwd
	cp -v claws-dev/$@ .
	
clean-origs:
	rm -f claws-mail-$(VERS).tar.gz

clean: clean-origs
	rm -rf claws-dev

mrproper: clean
	rm -rf claws

.PHONY: get-origs clean mrproper clean-origs update-claws 
